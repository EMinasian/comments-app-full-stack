
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Comment {
  commentId Int @default(autoincrement()) @id
  title String
  autorId Int
}

model User {
  id Int @default(autoincrement()) @id
  username String @unique
  email String @unique
  profilePictureUrl String
  password String
}